<UserControl x:Class="SistemaResidencial.Views.CambiarPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <materialDesign:Card Width="380" Padding="32" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
        <StackPanel>
            <TextBlock Text="Cambiar contraseña" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

            <PasswordBox x:Name="PasswordActualBox"
                         materialDesign:HintAssist.Hint="Contraseña actual"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         PasswordChanged="PasswordActualBox_PasswordChanged"
                         Margin="0,0,0,16" />

            <PasswordBox x:Name="NuevoPasswordBox"
                         materialDesign:HintAssist.Hint="Nueva contraseña"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         PasswordChanged="NuevoPasswordBox_PasswordChanged"
                         Margin="0,0,0,16" />

            <PasswordBox x:Name="ConfirmarPasswordBox"
                         materialDesign:HintAssist.Hint="Confirmar nueva contraseña"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         PasswordChanged="ConfirmarPasswordBox_PasswordChanged"
                         Margin="0,0,0,8" />

            <TextBlock Text="{Binding MensajeError}" Foreground="Red" FontSize="12" TextWrapping="Wrap" />
            <TextBlock Text="{Binding MensajeExito}" Foreground="Green" FontSize="12" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancelar" Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding CancelarCommand}" Margin="0,0,8,0" />
                <Button Content="Guardar" Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding GuardarCommand}" />
            </StackPanel>
        </StackPanel>
    </materialDesign:Card>
</UserControl>
